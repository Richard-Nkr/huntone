# ── Huntone Supabase Self-Hosted ──────────────────────────────────────────────
# Copier ce fichier en .env et remplacer les valeurs

# PostgreSQL
POSTGRES_PASSWORD=votre_mot_de_passe_securise
POSTGRES_DB=huntone

# Secrets JWT (générer avec: openssl rand -base64 32)
JWT_SECRET=generer_un_secret_jwt_32_caracteres
ANON_KEY=generer_une_cle_anon
SERVICE_ROLE_KEY=generer_une_cle_service_role

# URLs
API_EXTERNAL_URL=https://api.votre-domaine.com
SUPABASE_PUBLIC_URL=https://api.votre-domaine.com

# GoTrue Auth
GOTRUE_SITE_URL=https://votre-domaine.com
GOTRUE_JWT_EXP=3600
GOTRUE_MAILER_AUTOCONFIRM=false
GOTRUE_SMTP_HOST=smtp.resend.com
GOTRUE_SMTP_PORT=587
GOTRUE_SMTP_USER=votre_smtp_user
GOTRUE_SMTP_PASS=votre_smtp_password
GOTRUE_SMTP_SENDER_NAME=Huntone
GOTRUE_SMTP_ADMIN_EMAIL=hello@votre-domaine.com
GOTRUE_MAILER_SUBJECTS_CONFIRMATION="Confirme ton email Huntone"
GOTRUE_MAILER_TEMPLATES_CONFIRMATION=email_confirmation.html

# Storage
STORAGE_BACKEND=file
FILE_SIZE_LIMIT=52428800

# Studio
STUDIO_PORT=3000
